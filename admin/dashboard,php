// shown in dashboard summary cards.
// ======================================================



// ======================================================
// TOTAL USERS COUNT
// Counts all registered users in the system
// ======================================================

$total_users = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM users")

);



// ======================================================
// TOTAL DONORS COUNT
// Counts users whose role is donor
// ======================================================

$total_donors = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM users
    WHERE role='donor'")

);



// ======================================================
// TOTAL RECEIVERS COUNT
// Counts users who receive food donations
// ======================================================

$total_receivers = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM users
    WHERE role='receiver'")

);



// ======================================================
// TOTAL DELIVERY STAFF COUNT
// Counts all delivery personnel
// ======================================================

$total_delivery = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM users
    WHERE role='delivery'")

);



// ======================================================
// TOTAL FOOD ITEMS COUNT
// Counts all food records in database
// ======================================================

$total_food = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM food")

);



// ======================================================
// PENDING REQUESTS COUNT
// Counts food requests waiting for approval
// ======================================================

$pending_requests = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM requests
    WHERE status='pending'")

);



// ======================================================
// ACTIVE DELIVERIES COUNT
// Counts deliveries that are currently ongoing
// assigned OR picked up
// ======================================================

$active_delivery = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM deliveries
    WHERE status='assigned'
    OR status='picked_up'")

);



// ======================================================
// COMPLETED DELIVERIES COUNT
// Counts successfully delivered food
// ======================================================

$completed_delivery = mysqli_num_rows(

    mysqli_query($conn,
    "SELECT * FROM deliveries
    WHERE status='delivered'")

);




// ======================================================
// RECENT DELIVERIES SECTION
// Fetch latest 5 deliveries with related info
// using JOIN queries
// ======================================================

$recent_deliveries = mysqli_query($conn,

"SELECT deliveries.*,

receiver.name AS receiver_name,

delivery_user.name AS delivery_name,

food.food_name,

requests.status AS request_status

FROM deliveries


// Join requests table with deliveries

JOIN requests
ON deliveries.request_id = requests.request_id


// Join food table to get food details

JOIN food
ON requests.food_id = food.id


// Join receiver user information

JOIN users AS receiver
ON requests.receiver_id = receiver.id


// Join delivery staff information

JOIN users AS delivery_user
ON deliveries.delivery_user_id = delivery_user.id


// Show latest deliveries first

ORDER BY deliveries.delivery_id DESC


// Limit only latest 5 records

LIMIT 5");

?>



